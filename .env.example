# Copy this file to .env and fill in your paths.
# .env is gitignored — this file (.env.example) is the committed template.
#
# NAS share:  //192.168.1.30/usbshare
# NAS folder: media/music/Communion After Dark
#
# Source before running the scraper:
#   Linux:    source .env
#   Windows:  see PowerShell block below

# ---------------------------------------------------------------------------
# Linux  (NAS mounted at /mnt/nas — see NAS_SETUP.md for fstab entry)
# ---------------------------------------------------------------------------
export CAD_ARCHIVE_DIR="/mnt/nas/media/music/Communion After Dark/archive"
export CAD_DATA_DIR="/mnt/nas/media/music/Communion After Dark/data"

# ---------------------------------------------------------------------------
# Windows  (NAS mapped to Z: — see NAS_SETUP.md for net use command)
# ---------------------------------------------------------------------------
# $env:CAD_ARCHIVE_DIR = "Z:\media\music\Communion After Dark\archive"
# $env:CAD_DATA_DIR    = "Z:\media\music\Communion After Dark\data"
