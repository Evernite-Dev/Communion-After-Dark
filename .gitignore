# ---------------------------------------------------------------------------
# Archive data — never commit (audio files + artwork = hundreds of GB,
# SQLite database is a binary regenerated by the scraper)
# ---------------------------------------------------------------------------
archive/
/data/

# Local environment config (contains NAS paths, machine-specific overrides)
.env

# ---------------------------------------------------------------------------
# Licensed fonts — Adobe Fonts license prohibits redistribution of .ttf files
# Place font files locally; they are gitignored everywhere in the project.
# ---------------------------------------------------------------------------
*.ttf
*.otf

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Flatpak build artifacts
# ---------------------------------------------------------------------------
player/build/
player/.flatpak-builder/
player/repo/

# ---------------------------------------------------------------------------
# Partial downloads (created by http_client.py on interrupted transfers)
# ---------------------------------------------------------------------------
*.tmp

# ---------------------------------------------------------------------------
# Claude Code / LLM context files — local only, not for version control
# ---------------------------------------------------------------------------
.claude/
LLM_CONTEXT.md
PUBLIC_PLAN.md

# ---------------------------------------------------------------------------
# OS / editor noise
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~
